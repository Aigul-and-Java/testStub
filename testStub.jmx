      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler POST">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import org.apache.hc.client5.http.classic.methods.HttpPost
import org.apache.hc.client5.http.impl.classic.HttpClients
import org.apache.hc.core5.http.io.entity.StringEntity
import org.apache.hc.core5.http.ContentType
import groovy.json.JsonBuilder
import org.apache.hc.core5.http.io.entity.EntityUtils
import org.apache.jmeter.samplers.SampleResult


def sampleResult = new SampleResult()
sampleResult.sampleStart() 

try {
    def client = HttpClients.createDefault()
    def randomId = (10000 + new Random().nextInt(90000)).toString()
    def post = new HttpPost(&quot;http://localhost:8081/api/post&quot;)
    def json = new JsonBuilder([id: randomId]).toString()
    post.setEntity(new StringEntity(json, ContentType.APPLICATION_JSON))

    def response = client.execute(post)
    def result = EntityUtils.toString(response.getEntity())

    sampleResult.setResponseData(result, &quot;UTF-8&quot;)
    sampleResult.setResponseCode(response.getCode().toString())
    sampleResult.setSuccessful(response.getCode() == 200)

    client.close()
} catch (Exception e) {
    sampleResult.setResponseData(e.toString(), &quot;UTF-8&quot;)
    sampleResult.setResponseCode(&quot;500&quot;)
    sampleResult.setSuccessful(false)
} finally {
    sampleResult.sampleEnd()
}

return sampleResult</stringProp>
        </JSR223Sampler>
